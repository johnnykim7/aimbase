# docker compose 실행 시 사용되는 환경변수
# 사용법: cp .env.docker .env 후 값 수정

# LLM API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=sk-dummy

# Security
JWT_SECRET=local-dev-secret-min-32-characters-here!
ENCRYPTION_KEY=local-dev-enc-key-32-characters!!
PLATFORM_ADMIN_EMAIL=admin@platform.local
PLATFORM_ADMIN_PASSWORD=Admin1234!
