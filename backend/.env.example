# ── Server ──
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

# ── Master DB (테넌트 레지스트리, 구독 관리) ──
MASTER_DB_URL=jdbc:postgresql://localhost:5432/llm_platform_master
MASTER_DB_USERNAME=platform
MASTER_DB_PASSWORD=platform

# ── Tenant DB 기본값 (TenantOnboardingService에서 사용) ──
# 테넌트 프로비저닝 시 새 DB가 생성될 PostgreSQL 호스트
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_USERNAME=platform
TENANT_DB_PASSWORD=platform

# ── Redis ──
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# ── LLM API Keys ──
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ── 로컬 LLM ──
OLLAMA_BASE_URL=http://localhost:11434

# ── Adapters ──
SLACK_BOT_TOKEN=xoxb-xxx
KAKAO_APP_KEY=xxx

# ── Security ──
JWT_SECRET=change-me-in-production-min-32-chars
ENCRYPTION_KEY=change-me-in-production-32-chars!
PLATFORM_ADMIN_EMAIL=admin@platform.local
PLATFORM_ADMIN_PASSWORD=change-me-in-production
