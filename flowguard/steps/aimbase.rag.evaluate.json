{
  "type": "ACTION",
  "connector": "aimbase-mcp-rag",
  "action": {
    "method": "POST",
    "endpoint": "/mcp",
    "headers": {},
    "body": {
      "tool": "evaluate_rag",
      "arguments": {
        "question": "대한민국 수도는?",
        "answer": "대한민국의 수도는 서울입니다.",
        "contexts": ["대한민국의 수도는 서울이며, 인구는 약 5100만명이다."]
      }
    }
  },
  "extract": {
    "faithfulness": "$.body.result.faithfulness",
    "relevancy": "$.body.result.relevancy"
  },
  "assert": [
    { "field": "$.body.result.faithfulness", "operator": ">=", "value": 0.7 }
  ],
  "failMode": "hard"
}
