{
  "type": "ACTION",
  "connector": "aimbase-mcp-rag",
  "action": {
    "method": "POST",
    "endpoint": "/mcp",
    "headers": {},
    "body": {
      "tool": "advanced_parse",
      "arguments": {
        "content": "# 제목\n\n본문 내용입니다.\n\n## 소제목\n\n- 항목1\n- 항목2",
        "file_type": "markdown",
        "config": null
      }
    }
  },
  "extract": {
    "success": "$.body.result.success",
    "sectionCount": "$.body.result.sections.length",
    "firstSectionTitle": "$.body.result.sections[0].title"
  },
  "assert": [
    { "field": "$.body.result.success", "operator": "==", "value": true },
    { "field": "$.body.result.sections.length", "operator": ">=", "value": 1 }
  ],
  "failMode": "hard"
}
