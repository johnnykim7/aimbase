{
  "type": "UI_SMOKE",
  "connector": "aimbase-fe",
  "name": "라우팅: /workflows/:id/edit → 기존 워크플로우 로드",
  "action": {
    "url": "{{vars.feBaseUrl}}/workflows/{{vars.testWorkflowId}}/edit",
    "checkpoints": [
      {"selector": ".react-flow__node", "minCount": 1}
    ]
  },
  "assert": [
    { "field": "$.status", "operator": "==", "value": 200 }
  ],
  "failMode": "hard"
}
