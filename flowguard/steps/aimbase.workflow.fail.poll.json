{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "GET",
    "endpoint": "/workflows/{{steps.aimbase.workflow.fail.create.output.workflowId}}/runs/{{steps.aimbase.workflow.fail.run.output.runId}}",
    "headers": {}
  },
  "extract": {
    "status": "$.body.data.status",
    "error": "$.body.data.error"
  },
  "assert": [
    { "field": "$.body.data.status", "operator": "==", "value": "failed" },
    { "field": "$.body.data.error", "operator": "!=", "value": null }
  ],
  "retry": {"maxAttempts": 5, "intervalMs": 3000},
  "failMode": "hard"
}
