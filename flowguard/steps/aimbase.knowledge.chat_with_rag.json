{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/chat/completions",
    "headers": {},
    "body": {
      "model": "gpt-4o",
      "messages": [
        {
          "role": "user",
          "content": "대한민국의 인구는 얼마야?"
        }
      ],
      "rag_source_id": "{{steps.aimbase.knowledge.create.output.knowledgeSourceId}}"
    }
  },
  "extract": {
    "answer": "$.body.data.content[0].text"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true }
  ],
  "failMode": "hard"
}
