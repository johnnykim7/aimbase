{
  "type": "ACTION",
  "connector": "aimbase-mcp-rag",
  "action": {
    "method": "POST",
    "endpoint": "/mcp",
    "headers": {},
    "body": {
      "tool": "evaluate_rag",
      "arguments": {
        "source_id": "{{sourceId}}",
        "test_set": [
          {
            "question": "대한민국 수도는?",
            "answer": "대한민국의 수도는 서울입니다.",
            "contexts": ["대한민국의 수도는 서울이며, 인구는 약 5100만명이다."]
          }
        ],
        "config": null
      }
    }
  },
  "extract": {
    "success": "$.body.result.success",
    "sampleCount": "$.body.result.sample_count",
    "faithfulness": "$.body.result.metrics.faithfulness",
    "contextRelevancy": "$.body.result.metrics.context_relevancy"
  },
  "assert": [
    { "field": "$.body.result.success", "operator": "==", "value": true },
    { "field": "$.body.result.sample_count", "operator": ">=", "value": 1 },
    { "field": "$.body.result.metrics.faithfulness", "operator": ">=", "value": 0.5 }
  ],
  "failMode": "hard"
}
