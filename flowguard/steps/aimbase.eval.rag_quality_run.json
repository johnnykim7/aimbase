{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/evaluations/rag-quality",
    "headers": {},
    "body": {
      "source_id": "{{sourceId}}",
      "test_questions": ["대한민국 수도는?"],
      "metrics": ["faithfulness", "context_relevancy", "answer_relevancy"]
    }
  },
  "extract": {
    "evaluationId": "$.body.data.id",
    "status": "$.body.data.status"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true },
    { "field": "$.body.data.id", "operator": "!=", "value": null },
    { "field": "$.body.data.status", "operator": "in", "value": ["pending", "running", "completed"] }
  ],
  "failMode": "hard"
}
