{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/workflows/{{steps.aimbase.workflow.fail.create.output.workflowId}}/run",
    "headers": {},
    "body": {}
  },
  "extract": {
    "runId": "$.body.data.id"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true }
  ],
  "failMode": "hard"
}
