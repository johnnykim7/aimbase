{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/speech/tts",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "text": "안녕하세요, 테스트 음성입니다.",
      "model": "tts-1",
      "voice": "alloy",
      "speed": 1.0
    }
  },
  "extract": {
    "statusCode": "$.statusCode",
    "contentType": "$.headers.content-type"
  },
  "assert": [
    { "field": "$.statusCode", "operator": "in", "value": [200, 503] },
    { "field": "$.headers.content-type", "operator": "contains", "value": "audio", "when": "$.statusCode == 200" }
  ],
  "failMode": "soft"
}
