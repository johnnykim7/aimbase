{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "GET",
    "endpoint": "/workflows/{{steps.aimbase.workflow.dag.create.output.workflowId}}/runs/{{steps.aimbase.workflow.dag.run.output.runId}}",
    "headers": {}
  },
  "extract": {
    "status": "$.body.data.status",
    "s1Output": "$.body.data.stepResults.s1.output",
    "s2Output": "$.body.data.stepResults.s2.output"
  },
  "assert": [
    { "field": "$.body.data.status", "operator": "==", "value": "completed" },
    { "field": "$.body.data.stepResults.s2.output", "operator": "==", "value": "1100" }
  ],
  "retry": {"maxAttempts": 5, "intervalMs": 3000},
  "failMode": "hard"
}
