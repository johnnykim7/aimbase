{
  "type": "ACTION",
  "connector": "aimbase-platform-api",
  "action": {
    "method": "GET",
    "endpoint": "/platform/tenants/{{steps.aimbase.platform.tenant.create.output.tenantId}}/subscription",
    "headers": {}
  },
  "extract": {
    "plan": "$.body.data.plan",
    "quota": "$.body.data.monthlyTokenQuota"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true }
  ],
  "failMode": "hard"
}
