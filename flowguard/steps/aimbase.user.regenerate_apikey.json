{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/users/{{steps.aimbase.user.create.output.userId}}/api-key",
    "headers": {}
  },
  "extract": {
    "newApiKey": "$.body.data.apiKey"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true },
    { "field": "$.body.data.apiKey", "operator": "!=", "value": "{{steps.aimbase.user.create.output.apiKey}}" }
  ],
  "failMode": "hard"
}
