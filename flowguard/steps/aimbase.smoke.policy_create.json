{
  "type": "ACTION",
  "connector": "aimbase-api-raw",
  "name": "T4-4 #23: 정책 생성 API 확인 (CR-015)",
  "action": {
    "method": "POST",
    "endpoint": "/api/v1/policies",
    "headers": {
      "Authorization": "Bearer {{steps.aimbase.smoke.login.output.accessToken}}",
      "X-Tenant-Id": "{{vars.tenantId}}",
      "Content-Type": "application/json"
    },
    "body": {
      "id": "smoke-test-policy",
      "name": "Smoke Test Policy",
      "priority": 999,
      "rules": [{ "type": "token_limit", "max_tokens": 4096, "action": "DENY" }]
    }
  },
  "extract": {},
  "assert": [
    { "field": "$.statusCode", "operator": "in", "value": [200, 201, 409] }
  ],
  "failMode": "soft"
}
