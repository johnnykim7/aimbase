{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/chat/completions",
    "headers": {},
    "body": {
      "model": "gpt-4o",
      "messages": [
        {
          "role": "user",
          "content": "내 이름은 Alice야. 기억해줘."
        }
      ]
    }
  },
  "extract": {
    "sessionId": "$.body.data.session_id",
    "content": "$.body.data.content[0].text"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true },
    { "field": "$.body.data.session_id", "operator": "!=", "value": null }
  ],
  "failMode": "hard"
}
