{
  "type": "ACTION",
  "connector": "aimbase-api-raw",
  "name": "T4-4: 로그인 → 토큰 발급",
  "action": {
    "method": "POST",
    "endpoint": "/api/v1/auth/login",
    "headers": {
      "Content-Type": "application/json",
      "X-Tenant-Id": "{{vars.tenantId}}"
    },
    "body": {
      "email": "{{vars.adminEmail}}",
      "password": "{{vars.adminPassword}}"
    }
  },
  "extract": {
    "accessToken": "$.body.data.access_token",
    "userId": "$.body.data.user_id"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true },
    { "field": "$.body.data.access_token", "operator": "!=", "value": null }
  ],
  "failMode": "hard"
}
