{
  "type": "ACTION",
  "connector": "aimbase-mcp-rag",
  "action": {
    "method": "POST",
    "endpoint": "/mcp",
    "headers": {},
    "body": {
      "tool": "parent_child_search",
      "arguments": {
        "query": "플랫폼 아키텍처",
        "source_id": "{{sourceId}}",
        "top_k": 5
      }
    }
  },
  "extract": {
    "resultCount": "$.body.result.result_count",
    "success": "$.body.result.success",
    "firstParentId": "$.body.result.results[0].parent_id",
    "firstScore": "$.body.result.results[0].score"
  },
  "assert": [
    { "field": "$.body.result.success", "operator": "==", "value": true },
    { "field": "$.body.result.result_count", "operator": ">=", "value": 1 },
    { "field": "$.body.result.results[0].parent_id", "operator": "!=", "value": null }
  ],
  "failMode": "hard"
}
