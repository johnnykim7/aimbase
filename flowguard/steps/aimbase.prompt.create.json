{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/prompts",
    "headers": {},
    "body": {
      "name": "FlowGuard-Test-Prompt",
      "systemPrompt": "당신은 {{role}} 전문가입니다.",
      "variables": ["role"]
    }
  },
  "extract": {
    "promptId": "$.body.data.id"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true }
  ],
  "failMode": "hard"
}
