{
  "type": "PROBE_DB",
  "connector": "aimbase-tenant-db",
  "name": "테넌트 간 데이터 격리 검증",
  "action": {
    "query": "SELECT count(*) as cnt FROM connections WHERE id IN (SELECT id FROM connections)",
    "database": "{{vars.tenantBDbName}}"
  },
  "assert": [
    { "field": "$.rows[0].cnt", "operator": "==", "value": 0 }
  ],
  "failMode": "hard"
}
