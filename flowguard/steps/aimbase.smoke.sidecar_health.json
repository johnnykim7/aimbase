{
  "type": "ACTION",
  "connector": "aimbase-sidecar-raw",
  "name": "T4-4 #11: Python 사이드카 헬스체크",
  "action": {
    "method": "GET",
    "endpoint": "/health",
    "headers": {}
  },
  "extract": {
    "sidecarStatus": "$.body.status"
  },
  "assert": [
    { "field": "$.statusCode", "operator": "in", "value": [200, 503] }
  ],
  "failMode": "soft"
}
