{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/chat/completions",
    "headers": {},
    "body": {
      "model": "gpt-4o",
      "messages": [
        {
          "role": "user",
          "content": "현재 날씨 알려줘"
        }
      ],
      "tool_choice": "none"
    }
  },
  "extract": {
    "content": "$.body.data.content[0].text"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true },
    { "field": "$.body.data.content[0].type", "operator": "==", "value": "text" }
  ],
  "failMode": "hard"
}
