{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/workflows/{{steps.aimbase.workflow.dag.create.output.workflowId}}/run",
    "headers": {},
    "body": {
      "question": "대한민국의 수도는?",
      "expr": "250 * 4 + 100"
    }
  },
  "extract": {
    "runId": "$.body.data.id"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true }
  ],
  "failMode": "hard"
}
