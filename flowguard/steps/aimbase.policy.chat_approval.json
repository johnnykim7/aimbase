{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/chat/completions",
    "headers": {},
    "body": {
      "model": "approval-model",
      "messages": [
        {
          "role": "user",
          "content": "테스트 메시지"
        }
      ]
    }
  },
  "extract": {
    "approvalId": "$.body.data.approval_id"
  },
  "assert": [
    { "field": "$.body.data.status", "operator": "==", "value": "pending_approval" }
  ],
  "failMode": "hard"
}
