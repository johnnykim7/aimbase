{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/workflows",
    "headers": {},
    "body": {
      "name": "FlowGuard-DAG-WF",
      "description": "DAG 실행 테스트 (LLM_CALL → TOOL_CALL)",
      "domain": "test",
      "triggerConfig": {"type": "manual"},
      "steps": [
        {
          "id": "s1",
          "type": "LLM_CALL",
          "config": {
            "prompt": "다음 질문에 한 문장으로 답변해주세요: {{input.question}}",
            "model": "auto",
            "connection_id": "{{vars.connectionId}}"
          },
          "dependsOn": []
        },
        {
          "id": "s2",
          "type": "TOOL_CALL",
          "dependsOn": ["s1"],
          "config": {
            "tool": "calculate",
            "input": {"expression": "{{input.expr}}"}
          }
        }
      ]
    }
  },
  "extract": {
    "workflowId": "$.body.data.id"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true }
  ],
  "failMode": "hard"
}
