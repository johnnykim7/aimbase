{
  "type": "ACTION",
  "connector": "aimbase-mcp-rag",
  "action": {
    "method": "POST",
    "endpoint": "/mcp",
    "headers": {},
    "body": {
      "tool": "transform_query",
      "arguments": {
        "query": "임베딩 차원",
        "strategy": "hyde"
      }
    }
  },
  "extract": {
    "strategyUsed": "$.body.result.strategy_used",
    "transformedQueries": "$.body.result.transformed_queries",
    "queryCount": "$.body.result.transformed_queries.length"
  },
  "assert": [
    { "field": "$.body.result.strategy_used", "operator": "==", "value": "hyde" },
    { "field": "$.body.result.transformed_queries.length", "operator": ">=", "value": 2 }
  ],
  "failMode": "hard"
}
