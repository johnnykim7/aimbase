{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/connections",
    "headers": {},
    "body": {
      "name": "FlowGuard-Test-LLM",
      "type": "LLM",
      "adapterType": "OPENAI",
      "config": {
        "apiKey": "{{vars.openaiApiKey}}",
        "model": "gpt-4o"
      }
    }
  },
  "extract": {
    "connectionId": "$.body.data.id"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true }
  ],
  "failMode": "hard"
}
