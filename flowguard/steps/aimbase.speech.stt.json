{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/speech/stt",
    "headers": {
      "Content-Type": "multipart/form-data"
    },
    "body": {
      "file": "{{audioFilePath}}",
      "model": "whisper-1",
      "language": "ko"
    }
  },
  "extract": {
    "text": "$.body.data.text",
    "success": "$.body.success"
  },
  "assert": [
    { "field": "$.statusCode", "operator": "in", "value": [200, 503] },
    { "field": "$.body.data.text", "operator": "!=", "value": null, "when": "$.statusCode == 200" }
  ],
  "failMode": "soft"
}
