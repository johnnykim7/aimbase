{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/chat/completions",
    "headers": {},
    "body": {
      "model": "gpt-4o",
      "messages": [
        {
          "role": "user",
          "content": "Hello"
        }
      ]
    }
  },
  "extract": {
    "usedModel": "$.body.data.model"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true },
    { "field": "$.body.data.model", "operator": "contains", "value": "gpt" }
  ],
  "failMode": "hard"
}
