{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/schemas",
    "headers": {},
    "body": {
      "name": "FlowGuard-Test-Schema",
      "schema": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "age": {"type": "integer"}
        },
        "required": ["name"]
      }
    }
  },
  "extract": {
    "schemaId": "$.body.data.id"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true }
  ],
  "failMode": "hard"
}
