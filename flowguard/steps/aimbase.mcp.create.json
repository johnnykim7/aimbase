{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/mcp-servers",
    "headers": {},
    "body": {
      "name": "FlowGuard-Test-MCP",
      "url": "{{vars.mcpServerUrl}}",
      "description": "FlowGuard 테스트용 MCP 서버"
    }
  },
  "extract": {
    "mcpServerId": "$.body.data.id"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true }
  ],
  "failMode": "hard"
}
