{
  "type": "UI_SMOKE",
  "connector": "aimbase-fe",
  "name": "공통 컴포넌트 렌더링 (DataTable, Modal, Badge)",
  "action": {
    "url": "{{vars.feBaseUrl}}/connections",
    "checkpoints": [
      {"selector": "table, [data-testid=data-table]", "visible": true},
      {"selector": "[data-testid=badge], .badge", "visible": true}
    ]
  },
  "assert": [
    { "field": "$.status", "operator": "==", "value": 200 }
  ],
  "failMode": "hard"
}
