{
  "type": "ACTION",
  "connector": "aimbase-api",
  "action": {
    "method": "POST",
    "endpoint": "/knowledge-sources/{{steps.aimbase.knowledge.create.output.knowledgeSourceId}}/search",
    "headers": {},
    "body": {
      "query": "대한민국 인구",
      "topK": 5
    }
  },
  "extract": {
    "resultCount": "$.body.data.length"
  },
  "assert": [
    { "field": "$.body.success", "operator": "==", "value": true }
  ],
  "failMode": "hard"
}
