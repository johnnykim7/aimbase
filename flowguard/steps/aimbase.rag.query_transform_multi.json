{
  "type": "ACTION",
  "connector": "aimbase-mcp-rag",
  "action": {
    "method": "POST",
    "endpoint": "/mcp",
    "headers": {},
    "body": {
      "tool": "transform_query",
      "arguments": {
        "query": "성능 관련 설정 방법",
        "strategy": "multi_query"
      }
    }
  },
  "extract": {
    "strategyUsed": "$.body.result.strategy_used",
    "transformedQueries": "$.body.result.transformed_queries",
    "queryCount": "$.body.result.transformed_queries.length"
  },
  "assert": [
    { "field": "$.body.result.strategy_used", "operator": "==", "value": "multi_query" },
    { "field": "$.body.result.transformed_queries.length", "operator": ">=", "value": 3 }
  ],
  "failMode": "hard"
}
