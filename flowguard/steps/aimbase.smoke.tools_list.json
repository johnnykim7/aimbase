{
  "type": "ACTION",
  "connector": "aimbase-api-raw",
  "name": "T4-4 #20: 도구 목록 API 확인",
  "action": {
    "method": "GET",
    "endpoint": "/api/v1/tools",
    "headers": {
      "Authorization": "Bearer {{steps.aimbase.smoke.login.output.accessToken}}",
      "X-Tenant-Id": "{{vars.tenantId}}"
    }
  },
  "extract": {
    "toolCount": "$.body.data.total_count"
  },
  "assert": [
    { "field": "$.statusCode", "operator": "==", "value": 200 },
    { "field": "$.body.data.total_count", "operator": ">=", "value": 7 }
  ],
  "failMode": "hard"
}
